# Polaris environment variables.
# Copy to .env.local and fill in. ALL are optional for local development:
# with none set, Polaris uses an in-memory store and SIMULATES Twilio (sends are logged).

# ---- Twilio (required for live SMS + verification calls) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # your Twilio number, E.164 e.g. +14085550123

# Public origin Twilio can reach to fetch TwiML + hit callbacks.
# Local dev: an ngrok tunnel URL (ngrok http 3000). Prod: your Vercel URL.
PUBLIC_BASE_URL=

# Pre-verified phone that RECEIVES the "press 1 / press 2" verification call in demos,
# so you never dial a real shelter. (Twilio trial can only call verified numbers.)
DEMO_SHELTER_PHONE=

# Phone number shown on the landing page.
NEXT_PUBLIC_POLARIS_NUMBER=+1 (408) 555-0117

# ---- Optional: Backboard LLM enrichment (https://docs.backboard.io) ----
# When set, Backboard enriches constraint extraction for free-form messages. Deterministic
# extraction stays authoritative and replies stay template-based, so this only adds upside.
BACKBOARD_API_KEY=
BACKBOARD_PROVIDER=openai
BACKBOARD_MODEL=gpt-4o-mini
# BACKBOARD_BASE_URL=https://app.backboard.io/api   # override only if needed

# ---- Optional: shared state for multi-instance Vercel (Upstash Redis) ----
# Without these, state lives in memory (fine for local + a single warm serverless instance).
# Vercel-KV-style names (KV_REST_API_URL / KV_REST_API_TOKEN) are also accepted.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
